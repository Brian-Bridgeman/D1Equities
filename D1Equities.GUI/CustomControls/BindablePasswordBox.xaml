<UserControl x:Class="D1Equities.GUI.CustomControls.BindablePasswordBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:D1Equities.GUI.CustomControls"
             mc:Ignorable="d" 
             d:DesignHeight="30" d:DesignWidth="800">
    <PasswordBox x:Name="txtPassword"
                          FontSize="13"
                          FontWeight="Medium"
                          FontFamily="Arial"
                          Background="Transparent"
                          Foreground="White"
                          CaretBrush="LightGray"
                          SelectionBrush="{StaticResource D1Green}"
                          VerticalContentAlignment="Center"
                          FocusVisualStyle="{x:Null}">

        <PasswordBox.Style>

            <Style BasedOn="{x:Null}" TargetType="{x:Type PasswordBox}">
                <Setter Property="BorderThickness" Value="2"/>
                <Setter Property="Padding" Value="1"/>
                <Setter Property="AllowDrop" Value="true"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type PasswordBox}">
                            <Border x:Name="bg" BorderBrush="#656565" BorderThickness="0,0,0,1">
                                <ScrollViewer x:Name="PART_ContentHost" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Border>
                            <ControlTemplate.Triggers>

                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource D1Green}"/>
                                    <Setter TargetName="bg" Property="BorderThickness" Value="0,0,0,1"/>
                                </Trigger>

                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="bg" Property="BorderBrush" Value="{StaticResource D1Green}"/>
                                    <Setter TargetName="bg" Property="BorderThickness" Value="0,0,0,1"/>
                                </Trigger>

                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </PasswordBox.Style>

    </PasswordBox>
</UserControl>
