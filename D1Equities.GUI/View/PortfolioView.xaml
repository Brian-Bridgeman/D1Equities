<UserControl x:Class="D1Equities.GUI.View.PortfolioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:D1Equities.GUI.View"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:viewModel="clr-namespace:D1Equities.GUI.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">



    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- TOP PANEL -->
            <RowDefinition Height="*"/>
            <!-- MAIN PANEL -->
        </Grid.RowDefinitions>

        <!-- MAIN PANEL -->
        <Border Grid.Row="1"
        CornerRadius="10"
        Padding="20"
        BorderBrush="#333"
        BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#191919" Offset="0"/>
                    <GradientStop Color="#121212" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Header -->
                    <RowDefinition Height="*"/>
                    <!-- Scrollable list -->
                </Grid.RowDefinitions>

                <!-- HEADER ROW -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <!-- Ticker -->
                        <ColumnDefinition Width="1*"/>
                        <!-- Shares -->
                        <ColumnDefinition Width="1*"/>
                        <!-- Avg Price -->
                        <ColumnDefinition Width="1*"/>
                        <!-- Current Price -->
                        <ColumnDefinition Width="1*"/>
                        <!-- P/L % -->
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Ticker" Foreground="Gray" FontSize="16" FontWeight="Bold" Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="1" Text="Shares" Foreground="Gray" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Grid.Column="2" Text="Avg Price" Foreground="Gray" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Grid.Column="3" Text="Current" Foreground="Gray" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Grid.Column="4" Text="P/L %" Foreground="Gray" FontSize="16" FontWeight="Bold"/>
                </Grid>

                <!-- Scroll list -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Positions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <RadioButton Style="{StaticResource stockButton}"
                                     Command="{Binding DataContext.ShowStockViewCommand,
                                               RelativeSource={RelativeSource AncestorType=Window}}"
                                     CommandParameter="{Binding Ticker}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*"/>
                                            <!-- Ticker -->
                                            <ColumnDefinition Width="1*"/>
                                            <!-- Shares -->
                                            <ColumnDefinition Width="1*"/>
                                            <!-- Avg Price -->
                                            <ColumnDefinition Width="1*"/>
                                            <!-- Current Price -->
                                            <ColumnDefinition Width="1*"/>
                                            <!-- P/L % -->
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Ticker}" Foreground="White" FontSize="20" FontWeight="Medium"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Shares}" Foreground="White" FontSize="18"/>
                                        <TextBlock Grid.Column="2" Text="{Binding AveragePrice}" Foreground="White" FontSize="18" Margin="7,0,0,0"/>
                                        <TextBlock Grid.Column="3" Text="{Binding CurrentPrice}" Foreground="White" FontSize="18" Margin="10,0,0,0"/>
                                        <TextBlock Grid.Column="4" 
                                        Text="{Binding ProfitPercent}" 
                                        Foreground="{Binding ProfitPercent, Converter={StaticResource PercentToColorConverter}}" 
                                        FontSize="18" 
                                        Margin="10,0,0,0"/>
                                    </Grid>
                                </RadioButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>


    </Grid>

</UserControl>
