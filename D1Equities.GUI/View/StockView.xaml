<UserControl x:Class="D1Equities.GUI.View.StockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:viewModel="clr-namespace:D1Equities.GUI.ViewModel"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:local="clr-namespace:D1Equities.GUI.View"
             Background="Transparent"
             MinHeight="500"
             MinWidth="900">


    
    <!-- Gradient border -->
    <Border CornerRadius="15" Padding="2">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#191919" Offset="0"/>
                <GradientStop Color="#121212" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <!-- Window drop Shadow -->
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" Opacity="0.3" ShadowDepth="5"/>
        </Border.Effect>

        <!-- Content container -->
        <Border CornerRadius="13" Background="Transparent" ClipToBounds="True">
            <Grid>
                <!-- Define columns: Chart on the left, Text on the right -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <!-- Chart takes remaining space -->
                    <ColumnDefinition Width="200" />
                    <!-- Right panel fixed width -->
                </Grid.ColumnDefinitions>

                <!-- GRID ROWS: Top info / Chart -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Top box -->
                    <RowDefinition Height="*"/>
                    <!-- Chart fills remaining space -->
                </Grid.RowDefinitions>

                <!-- Top box -->
                <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#221E1E1E" CornerRadius="10" Margin="15,15,15,5">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="10" Opacity="0.2" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel Orientation="Vertical" Margin="15">
                        <!-- Ticker on top-left -->
                        <TextBlock Text="{Binding Ticker}" Foreground="White" FontSize="25" FontWeight="Light" VerticalAlignment="Top"/>
                        <!-- Company name below ticker -->
                        <TextBlock Text="{Binding CompanyName}" Foreground="Gray" FontSize="17" FontWeight="Light" Margin="0,5,0,0"/>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">
                            <!-- Dollar sign -->
                            <TextBlock Text="$" Foreground="White" FontSize="35" FontWeight="Light" VerticalAlignment="Center"/>
                            <!-- Price -->
                            <TextBlock Text="{Binding CurrentPrice}" Foreground="White" FontSize="35" FontWeight="Light" VerticalAlignment="Center"/>
                            <!-- Price Difference -->
                            <TextBlock Text="{Binding PriceDifference}" Foreground="{StaticResource D1Green}" FontSize="15" FontWeight="Light" Margin="10,0,0,25" VerticalAlignment="Center"/>
                            <!-- Percent Change -->
                            <TextBlock Text="(" Foreground="{StaticResource D1Green}" FontSize="15" FontWeight="Light" Margin="5,0,0,25" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding PercentChange}" Foreground="{StaticResource D1Green}" FontSize="15" FontWeight="Light" Margin="0,0,0,25" VerticalAlignment="Center"/>
                            <TextBlock Text="%" Foreground="{StaticResource D1Green}" FontSize="15" FontWeight="Light" Margin="0,0,0,25" VerticalAlignment="Center"/>
                            <TextBlock Text=")" Foreground="{StaticResource D1Green}" FontSize="15" FontWeight="Light" Margin="0,0,0,25" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>


                <!-- Chart -->
                <oxy:PlotView Grid.Row="1" Grid.Column="0"
                  Model="{Binding CandlestickModel}"
                  Margin="15"
                  Background="Transparent"/>

                <!-- Right Panel-->
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,15,15,15" VerticalAlignment="Top">
                    <TextBlock Text="Stock Info" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                    <!-- Repeats automatically for each item -->
                    <ItemsControl ItemsSource="{Binding StockDetails}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Label}" Foreground="Gray" FontSize="14" Grid.Column="0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Value}" Foreground="Gray" FontSize="14" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Vertical" Margin="0,30,0,0">
                        <!-- Buy Button -->
                        <Button Content="Buy"
                                Height="35"
                                Command="{Binding BuyCommand}"
                                Foreground="White"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,10"
                                BorderBrush="#555" BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Root"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="5">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#081e19" Offset="0"/>
                                                <GradientStop Color="#00895d" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>

                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <!-- Hover -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Root" Property="Opacity" Value="0.85"/>
                                        </Trigger>

                                        <!-- Pressed -->
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Root" Property="Opacity" Value="0.7"/>
                                        </Trigger>

                                        <!-- Disabled -->
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="Root" Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>

                        <!-- Sell Button -->
                        <Button Content="Sell"
                                Height="35"
                                Command="{Binding SellCommand}"
                                Foreground="White"
                                HorizontalAlignment="Stretch"
                                BorderBrush="#555" BorderThickness="1">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Root"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="5">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#191919" Offset="0"/>
                                                <GradientStop Color="#121212" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>

                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <!-- Hover -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Root" Property="Opacity" Value="0.85"/>
                                        </Trigger>

                                        <!-- Pressed -->
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Root" Property="Opacity" Value="0.7"/>
                                        </Trigger>

                                        <!-- Disabled -->
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="Root" Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>
                    </StackPanel>

                </StackPanel>
            </Grid>

        </Border>
    </Border>
</UserControl>
