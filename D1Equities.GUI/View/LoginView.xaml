<Window x:Class="D1Equities.GUI.View.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:D1Equities.GUI.View"
        mc:Ignorable="d"
        Title="LoginView" Height="600" Width="400"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        MouseDown="Window_MouseDown">
    <Border CornerRadius="50">
        <Border.Background>
            <ImageBrush ImageSource="/Images/pexels-alesiakozik-6781008.jpg"
                     Stretch="UniformToFill"/>
        </Border.Background>

        <Border CornerRadius="10"
         BorderThickness="3"
         Opacity="0.95">

            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1E1E1E" Offset="0.0"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0D0D0D" Offset="0.0"/>
                    <GradientStop Color="#2C2C2C" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="25"/>
                        <ColumnDefinition Width="25"/>
                        <ColumnDefinition Width="5"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnMinimize"
                         BorderThickness="0"
                         Content="-"
                         Foreground="White"
                         FontSize="16"
                         FontFamily="Arial"
                         Cursor="Hand"
                         Grid.Column="1"
                         Click="btnMinimize_Click">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#656565"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#ADADAD"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="18" Height="18"
                                     CornerRadius="9"
                                     Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>

                    </Button>

                    <Button x:Name="btnClose"
                         BorderThickness="0"
                         Content="X"
                         Foreground="White"
                         FontSize="10"
                         FontFamily="Arial"
                         Cursor="Hand"
                         Grid.Column="2"
                         Click="btnClose_Click">

                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#656565"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#B00000"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="18" Height="18"
                                     CornerRadius="9"
                                     Background="{TemplateBinding Background}">
                                    <ContentPresenter VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>

                    </Button>

                </Grid>

                <StackPanel Width="500"
                         Grid.Row="1"
                         Orientation="Vertical"
                         HorizontalAlignment="Center"
                         Margin="0,10,0,0">
                    <Image Source="/Images/a528cf36-feec-459d-88cf-5a391efd7218.png"
                        Width="175" Height="175"
                        Margin="0,0,0,0"/>


                    <TextBlock Text="Invest from Day One."
                            Foreground="LightGray"
                            FontSize="12"
                            FontWeight="Medium"
                            FontFamily="Arial"
                            TextWrapping="Wrap"
                            TextAlignment="Center"
                            Margin="0,-20,0,0"/>

                    <StackPanel Width="200"
                             Grid.Row="1"
                             Orientation="Vertical"
                             Margin="0,20,0,0">
                        <TextBlock Text="Username"
                            Foreground="DarkGray"
                            FontSize="12"
                            FontWeight="Medium"
                            FontFamily="Arial"
                            Margin="0,25,0,0"/>

                        <TextBox x:Name="txtUser"
                          FontSize="13"
                          FontWeight="Medium"
                          FontFamily="Arial"
                          Background="Transparent"
                          Foreground="White"
                          CaretBrush="LightGray"
                          Height="28"
                          VerticalContentAlignment="Center"
                          Margin="0,10,0,0"
                          FocusVisualStyle="{x:Null}">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="BorderBrush" Value="#656565"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#0bd851"/>
                                        </Trigger>
                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                            <Setter Property="BorderBrush" Value="#0bd851"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>

                        </TextBox>

                        <TextBlock Text="Password"
                            Foreground="DarkGray"
                            FontSize="12"
                            FontWeight="Medium"
                            FontFamily="Arial"
                            Margin="0,25,0,0"/>
                        <PasswordBox x:Name="txtPass"
                          FontSize="13"
                          FontWeight="Medium"
                          FontFamily="Arial"
                          Background="Transparent"
                          Foreground="White"
                          CaretBrush="LightGray"
                          Height="28"
                          VerticalContentAlignment="Center"
                          Margin="0,5,0,0"
                          FocusVisualStyle="{x:Null}">

                            <PasswordBox.Style>
                                <Style TargetType="PasswordBox">
                                    <Setter Property="BorderBrush" Value="#656565"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#0bd851"/>
                                        </Trigger>
                                        <Trigger Property="IsKeyboardFocused" Value="True">
                                            <Setter Property="BorderBrush" Value="#0bd851"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </PasswordBox.Style>

                        </PasswordBox>


                        <Button x:Name="btnLogin"
                         BorderThickness="0"
                         Content="LOGIN"
                         Foreground="White"
                         FontSize="10"
                         FontFamily="Arial"
                         Cursor="Hand"
                         Grid.Column="2"
                         Margin="0,50,0,0"
                         Opacity="1"
                         Click="btnLogin_Click">

                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#0cd950"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#64F795"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Width="150" Height="40"
                                     CornerRadius="20"
                                     Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,15,0,0">
                            <TextBlock Text="Don't have an account?"
                            Foreground="DarkGray"
                            FontSize="12"
                            FontWeight="Medium"
                            FontFamily="Arial"
                            TextWrapping="Wrap"
                            TextAlignment="Center"/>

                            <TextBlock Text="Sign up."
                            Foreground="White"
                            FontSize="12"
                            FontWeight="Medium"
                            FontFamily="Arial"
                            Cursor="Hand"
                            TextWrapping="Wrap"
                            TextAlignment="Center"
                            Margin="8,0,0,0"/>
                        </StackPanel>                        
                       

                    </StackPanel>

                </StackPanel>

            </Grid>

        </Border>

    </Border>
</Window>
