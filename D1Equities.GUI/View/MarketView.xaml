<UserControl x:Class="D1Equities.GUI.View.MarketView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:D1Equities.GUI.View"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:viewModel="clr-namespace:D1Equities.GUI.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">



        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <!-- Main panel takes most space -->
                <ColumnDefinition Width="250" />
                <!-- Right panel fixed smaller width -->
            </Grid.ColumnDefinitions>

            <!-- Main panel (current gradient panel) -->
            <Border Grid.Column="0"
            CornerRadius="10"
            Padding="20"
            BorderBrush="#333"
            BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#191919" Offset="0"/>
                        <GradientStop Color="#121212" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <!-- Existing Grid with Search + List goes here -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Search bar -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,15">
                        <TextBox x:Name="SearchBox"
                     Width="250"
                     Height="32"
                     VerticalAlignment="Center"
                     Padding="10,5"
                     FontSize="16"
                     Background="#2A2A2A"
                     Foreground="White"
                     BorderBrush="#444"
                     BorderThickness="1"/>
                    </DockPanel>

                    <!-- Scrollable list -->
                <!-- Scrollable list -->
                <ScrollViewer Grid.Row="1"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled">

                    <StackPanel x:Name="ItemsPanel" Orientation="Vertical">

                        <RadioButton Style="{StaticResource stockButton}"
                     Tag="LightGray"
                     Command="{Binding DataContext.ShowStockViewCommand,
                               RelativeSource={RelativeSource AncestorType=Window}}">

                            <Grid Margin="10,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <!-- Left side stretches -->
                                    <ColumnDefinition Width="Auto"/>
                                    <!-- Right side fits contents -->
                                </Grid.ColumnDefinitions>

                                <!-- LEFT SIDE: Ticker -->
                                <TextBlock Grid.Column="0"
                           Text="AAPL"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Medium"
                           VerticalAlignment="Center"/>

                                <!-- RIGHT SIDE: Price + Percent -->
                                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="20,0,0,0">
                                    <!-- small space between left/right -->

                                    <TextBlock Text="$"
                               Foreground="White"
                               FontSize="18"
                               Margin="0,0,2,0"/>

                                    <TextBlock Text="{Binding Price}"
                               Foreground="White"
                               FontSize="18"
                               Margin="0,0,8,0"/>

                                    <TextBlock Text="+"
                               Foreground="{StaticResource D1Green}"
                               FontSize="18"
                               Margin="0,0,2,0"/>

                                    <TextBlock Text="{Binding Percent}"
                               Foreground="{StaticResource D1Green}"
                               FontSize="18"
                               Margin="0,0,2,0"/>

                                    <TextBlock Text="%"
                               Foreground="{StaticResource D1Green}"
                               FontSize="18"/>
                                </StackPanel>

                            </Grid>

                        </RadioButton>

                    </StackPanel>

                </ScrollViewer>

            </Grid>
            </Border>

            <!-- Right panel -->
            <Border Grid.Column="1"
            CornerRadius="10"
            Padding="15"
            Margin="10,0,0,0"
            BorderBrush="#333"
            BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#191919" Offset="0"/>
                    <GradientStop Color="#121212" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel>
                    <TextBlock Text="Right Panel" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                    <!-- Add your content here -->
                </StackPanel>
            </Border>
        </Grid>

</UserControl>
