<UserControl x:Class="D1Equities.GUI.View.MarketView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:D1Equities.GUI.View"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:viewModel="clr-namespace:D1Equities.GUI.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    

    <Border Grid.Column="0"
                Background="#191919"
                CornerRadius="10"
                Margin="10"
                Padding="20"
                BorderBrush="#333"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Search bar -->
                    <RowDefinition Height="*"/>
                    <!-- Scrollable list -->
                </Grid.RowDefinitions>

                <!-- Search bar -->
                <DockPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBox x:Name="SearchBox"
               Width="250"
               Height="32"
               VerticalAlignment="Center"
               Padding="10,5"
               FontSize="16"
               Background="#2A2A2A"
               Foreground="White"
               BorderBrush="#444"
               BorderThickness="1"/>
                </DockPanel>

                <!-- Scrollable list -->
                <ScrollViewer Grid.Row="1"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">

                    <StackPanel x:Name="ItemsPanel" Orientation="Vertical">
                        <!-- Example items (replace with data binding later) -->
                        <RadioButton Style="{StaticResource menuButton}"
                                 Tag="LightGray"
                                 Command="{Binding DataContext.ShowStockViewCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}">

                            <StackPanel Orientation="Horizontal">
                                <fa:IconImage Icon="Home" Style="{StaticResource menuButtonIcon}"/>
                                <TextBlock Text="AAPL" Style="{StaticResource menuButtonText}"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                    
                </ScrollViewer>
            </Grid>
        </Border>

</UserControl>
