<UserControl x:Class="D1Equities.GUI.View.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:D1Equities.GUI.View"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1050"
             Background="#151515">

    <!-- Main Grid: Split horizontally into left and right -->
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <!-- Left half -->
            <ColumnDefinition Width="*" />
            <!-- Right half -->
        </Grid.ColumnDefinitions>

        <!-- Left full section -->
        <Border Grid.Column="0"
        Background="#191919"
        CornerRadius="10"
        Margin="10"
        Padding="20"
        BorderBrush="#333"
        BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Search bar -->
                    <RowDefinition Height="*"/>
                    <!-- Scrollable list -->
                </Grid.RowDefinitions>

                <!-- Search bar -->
                <DockPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBox x:Name="SearchBox"
                     Width="250"
                     Height="32"
                     VerticalAlignment="Center"
                     Padding="10,5"
                     FontSize="16"
                     Background="#2A2A2A"
                     Foreground="White"
                     BorderBrush="#444"
                     BorderThickness="1"/>
                </DockPanel>

                <!-- Scrollable list -->
                <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

                    <StackPanel x:Name="ItemsPanel" Orientation="Vertical">
                        <!-- Example items (replace with data binding later) -->
                        <Border Background="#2A2A2A" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                            <TextBlock Text="Item 1" Foreground="White" FontSize="16"/>
                        </Border>

                        <Border Background="#2A2A2A" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                            <TextBlock Text="Item 2" Foreground="White" FontSize="16"/>
                        </Border>

                        <Border Background="#2A2A2A" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                            <TextBlock Text="Item 3" Foreground="White" FontSize="16"/>
                        </Border>
                    </StackPanel>

                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Right half: split vertically -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <!-- Top right -->
                <RowDefinition Height="*" />
                <!-- Bottom right -->
            </Grid.RowDefinitions>

            <!-- Top right section -->
            <Border Grid.Row="0"
                    Background="#191919"
                    CornerRadius="12"
                    Margin="10"
                    Padding="25"
                    BorderBrush="#333"
                    BorderThickness="1">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Main title -->
                    <TextBlock Text="Total Portfolio Value"
                   Foreground="{StaticResource D1Green}"
                   FontSize="22"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

                    <!-- Big number -->
                    <TextBlock Text="$124,590.23"
                   Grid.Row="1"
                   Foreground="White"
                   FontSize="42"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>

                    <!-- Growth indicator -->
                    <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,20">

                        <TextBlock Text="+2.45% Today"
                       Foreground="{StaticResource D1Green}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,15,0"/>

                        <TextBlock Text="+$2,985.33"
                       Foreground="{StaticResource D1Green}"
                       FontSize="18"
                       FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Extra info section -->
                    <StackPanel Grid.Row="3"
                                Orientation="Vertical"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Margin="0,15,0,0"
                                Width="250">

                        <TextBlock Text="• All-Time Change: +24.59%"
                                   Foreground="#C8C8C8"
                                   FontSize="16"
                                   Margin="0,5"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="• Total Return (Value): +$24,590.23"
                                   Foreground="#C8C8C8"
                                   FontSize="16"
                                   Margin="0,5"/>

                        <TextBlock Text="• Last updated: 2 minutes ago"
                                   Foreground="#888"
                                   FontSize="14"
                                   Margin="0,10"/>
                    </StackPanel>

                </Grid>
            </Border>

            <!-- Bottom right section (graph sits here) -->
            <Border Grid.Row="1" Background="#191919" CornerRadius="10" Margin="10" Padding="15" BorderBrush="#333333" BorderThickness="1">
                <StackPanel Orientation="Vertical">

                    <!-- Title text -->
                    <TextBlock Text="Portfolio Growth (USD)"
                   Foreground="White" 
                   FontSize="15" 
                   FontWeight="Medium"
                   Margin="0,0,0,10"
                   HorizontalAlignment="Center"/>

                    <!-- Chart fills remaining space -->
                    <lvc:CartesianChart LegendLocation="None" Height="200">
                        <lvc:CartesianChart.DataTooltip>
                            <lvc:DefaultTooltip Background="Transparent" Foreground="{StaticResource D1Green}"/>
                        </lvc:CartesianChart.DataTooltip>

                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis Foreground="Green" ShowLabels="true" Labels="">
                                <lvc:Axis.Separator>
                                    <lvc:Separator StrokeThickness="0" Step="1" />
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisX>

                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Foreground="Green" ShowLabels="true" MinValue="0">
                                <lvc:Axis.Separator>
                                    <lvc:Separator StrokeThickness="0"/>
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisY>

                        <lvc:CartesianChart.Series>
                            <lvc:LineSeries StrokeThickness="2" 
                                Stroke="{StaticResource D1Green}" 
                                PointGeometrySize="10"
                                LineSmoothness="0"
                                Values="503,350,405,353,65,242,649,349,245,493,439,495,339,110,439,203,209,594,405,439">
                                <lvc:LineSeries.Fill>
                                    <LinearGradientBrush>
                                        <GradientStop Color="#066F29" Offset="0.4"/>
                                        <GradientStop Color="#191919" Offset="1.2"/>
                                    </LinearGradientBrush>
                                </lvc:LineSeries.Fill>
                            </lvc:LineSeries>
                        </lvc:CartesianChart.Series>
                    </lvc:CartesianChart>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>