<UserControl x:Class="D1Equities.GUI.View.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:D1Equities.GUI.View"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1050"
             Background="#151515">

    <!-- Main Grid: Split horizontally into left and right -->
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <!-- Left half -->
            <ColumnDefinition Width="400" />
            <!-- Right half -->
        </Grid.ColumnDefinitions>

        <!-- Left full section -->
        <Border Grid.Column="0"
        Background="#191919"
        CornerRadius="10"
        Margin="10"
        Padding="20"
        BorderBrush="#333"
        BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Search bar -->
                    <RowDefinition Height="*"/>
                    <!-- Scrollable list -->
                </Grid.RowDefinitions>

                <!-- Search bar -->
                <DockPanel Grid.Row="0" Margin="0,0,0,25">
                    <TextBox x:Name="SearchBox"
                     Width="250"
                     Height="32"
                     VerticalAlignment="Center"
                     Padding="10,5"
                     FontSize="16"
                     Background="#2A2A2A"
                     Foreground="White"
                     BorderBrush="#444"
                     BorderThickness="1"/>
                </DockPanel>

                <!-- Scrollable list -->
                <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalAlignment="Top"
                      Height="150">

                    <StackPanel x:Name="ItemsPanel" Orientation="Vertical">
                        <!-- Example items (replace with data binding later) -->
                        
                        <RadioButton Style="{StaticResource stockButton}" Margin="0,0,0,5"
                                 Tag="LightGray"
                                 Command="{Binding DataContext.ShowStockViewCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}">

                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                                <TextBlock Text="A" Style="{StaticResource menuButtonText}" FontSize="12"/>
                            </StackPanel>
                        </RadioButton>

                        <RadioButton Style="{StaticResource stockButton}" Margin="0,0,0,5"
                                 Tag="LightGray"
                                 Command="{Binding DataContext.ShowStockViewCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}">

                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                                <TextBlock Text="B" Style="{StaticResource menuButtonText}" FontSize="12"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource stockButton}" Margin="0,0,0,5"
                                 Tag="LightGray"
                                 Command="{Binding DataContext.ShowStockViewCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}">

                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                                <TextBlock Text="C" Style="{StaticResource menuButtonText}" FontSize="12"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource stockButton}" Margin="0,0,0,5"
                                 Tag="LightGray"
                                 Command="{Binding DataContext.ShowStockViewCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}">

                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                                <TextBlock Text="D" Style="{StaticResource menuButtonText}" FontSize="12"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource stockButton}" Margin="0,0,0,5"
                                 Tag="LightGray"
                                 Command="{Binding DataContext.ShowStockViewCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}">

                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                                <TextBlock Text="E" Style="{StaticResource menuButtonText}" FontSize="12"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource stockButton}" Margin="0,0,0,5"
                                 Tag="LightGray"
                                 Command="{Binding DataContext.ShowStockViewCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}">

                            <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                                <TextBlock Text="F" Style="{StaticResource menuButtonText}" FontSize="12"/>
                            </StackPanel>
                        </RadioButton>

                    </StackPanel>

                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Right half merged section with narrower width -->
        <Grid Grid.Column="1" Margin="0,10,10,10">
            <Border Background="#191919"
            CornerRadius="12"
            Padding="25"
            BorderBrush="#333"
            BorderThickness="1"
            Width="390">
                <!-- narrower than the full right half -->

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Stats section -->
                        <RowDefinition Height="*"/>
                        <!-- Chart section -->
                    </Grid.RowDefinitions>

                    <!-- Stats section (top) -->
                    <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                        <TextBlock Text="Total Portfolio Value"
                           Foreground="{StaticResource D1Green}"
                           FontSize="22"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>

                        <TextBlock Text="$124,590.23"
                           Foreground="White"
                           FontSize="42"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,20">
                            <TextBlock Text="+2.45% Today"
                               Foreground="{StaticResource D1Green}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,15,0"/>
                            <TextBlock Text="+$2,985.33"
                               Foreground="{StaticResource D1Green}"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                        </StackPanel>

                        <StackPanel Orientation="Vertical"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,0,0,15"
                            Width="250">
                            <TextBlock Text="• All-Time Change: +24.59%"
                               Foreground="#C8C8C8"
                               FontSize="16"
                               Margin="0,5"
                               HorizontalAlignment="Center"/>
                            <TextBlock Text="• Total Return (Value): +$24,590.23"
                               Foreground="#C8C8C8"
                               FontSize="16"
                               Margin="0,5"/>
                            <TextBlock Text="• Last updated: 2 minutes ago"
                               Foreground="#888"
                               FontSize="14"
                               Margin="0,10"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Chart section (bottom) -->
                    <Border Grid.Row="1"
                    Background="#151515"
                    CornerRadius="10"
                    Padding="10"
                    Margin="0,10,0,0"
                    BorderBrush="#222"
                    BorderThickness="1">

                        <lvc:CartesianChart LegendLocation="None" Height="200">
                            <lvc:CartesianChart.DataTooltip>
                                <lvc:DefaultTooltip Background="Transparent" Foreground="{StaticResource D1Green}"/>
                            </lvc:CartesianChart.DataTooltip>

                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Foreground="Green" ShowLabels="true" Labels="">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator StrokeThickness="0" Step="1" />
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>

                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Foreground="Green" ShowLabels="true" MinValue="0">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator StrokeThickness="0"/>
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisY>

                            <lvc:CartesianChart.Series>
                                <lvc:LineSeries StrokeThickness="2" 
                                        Stroke="{StaticResource D1Green}" 
                                        PointGeometrySize="10"
                                        LineSmoothness="0"
                                        Values="503,350,405,353,65,242,649,349,245,493,439,495,339,110,439,203,209,594,405,439">
                                    <lvc:LineSeries.Fill>
                                        <LinearGradientBrush>
                                            <GradientStop Color="#066F29" Offset="0.4"/>
                                            <GradientStop Color="#191919" Offset="1.2"/>
                                        </LinearGradientBrush>
                                    </lvc:LineSeries.Fill>
                                </lvc:LineSeries>
                            </lvc:CartesianChart.Series>
                        </lvc:CartesianChart>
                    </Border>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>