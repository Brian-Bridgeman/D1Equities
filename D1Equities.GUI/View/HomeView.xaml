<UserControl x:Class="D1Equities.GUI.View.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModel="clr-namespace:D1Equities.GUI.ViewModel"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:local="clr-namespace:D1Equities.GUI.View"
             Background="Transparent"
             MinHeight="500"
             MinWidth="900">

    <UserControl.DataContext>
        <viewModel:HomeViewModel/>
    </UserControl.DataContext>

    <!-- OUTER BORDER: Gradient border with shadow -->
    <Border CornerRadius="15" Padding="10">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#191919" Offset="0"/>
                <GradientStop Color="#121212" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <!-- Top row (3 boxes) -->
                <RowDefinition Height="3*"/>
                <!-- Bottom rectangle -->
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- TOP: 3 boxes -->
            <Border Grid.Row="0" Grid.Column="0" Margin="12" CornerRadius="8" BorderThickness="1" BorderBrush="#292929">
                
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#081e19" Offset="0"/>
                        <GradientStop Color="#0d251f" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel Orientation="Vertical" Margin="15,50,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Total Portfolio Value" Foreground="#a1a1a1" FontSize="20"
                       FontWeight="Light" VerticalAlignment="Center"/>

                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                        <TextBlock Text="$"
               Foreground="White"
               FontSize="25"
               FontWeight="Light"
               VerticalAlignment="Center"/>

                        <TextBlock Text="{Binding TotalEquity}"
               Foreground="White"
               FontSize="30"
               FontWeight="Light"
               VerticalAlignment="Center"
               Margin="5,0,0,0"/>
                    </StackPanel>

                    <!-- NEW BALANCE LINE -->
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="Balance: "
               Foreground="#a1a1a1"
               FontSize="16"
               FontWeight="Light"
               VerticalAlignment="Center"/>

                        <TextBlock Text="$ "
               Foreground="White"
               FontSize="18"
               FontWeight="Light"
               VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Balance}"
               Foreground="White"
               FontSize="18"
               FontWeight="Light"
               VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Margin="12" CornerRadius="8" BorderThickness="1" BorderBrush="#292929">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#191919" Offset="0"/>
                        <GradientStop Color="#121212" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel Orientation="Vertical" Margin="15,50,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Total Gain/Loss" Foreground="#a1a1a1" FontSize="20"
                       FontWeight="Light" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                        <TextBlock Text="$" Foreground="{Binding TotalValueChange, Converter={StaticResource PercentToColorConverter}}" FontSize="25" FontWeight="Light" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalValueChange}" 
                                   Foreground="{Binding TotalValueChange, Converter={StaticResource PercentToColorConverter}}" 
                                   FontSize="30" FontWeight="Light" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">

                        <TextBlock Text="{Binding TotalPercentageChange}"
                           Foreground="{Binding TotalPercentageChange, Converter={StaticResource PercentToColorConverter}}"
                           FontSize="20" FontWeight="Light" VerticalAlignment="Center"/>

                        <TextBlock Text="%" 
                           Foreground="{Binding TotalPercentageChange, Converter={StaticResource PercentToColorConverter}}"
                           FontSize="20" FontWeight="Light" VerticalAlignment="Center"
                           Margin="2,0,0,0"/>

                    </StackPanel>

                </StackPanel>                
            </Border>

            <Border Grid.Row="0" Grid.Column="2" Margin="12" CornerRadius="8" BorderThickness="1" BorderBrush="#292929">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#191919" Offset="0"/>
                        <GradientStop Color="#121212" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel Orientation="Vertical" Margin="15,50,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Total Holdings" Foreground="#a1a1a1" FontSize="20"
                       FontWeight="Light" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                        <TextBlock Text="{Binding TotalStocksOwned}" Foreground="White" FontSize="25"
                       FontWeight="Light" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                        <TextBlock Text="Different Stocks" Foreground="#a1a1a1" FontSize="20"
                       FontWeight="Light" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
        Margin="12" CornerRadius="10" BorderThickness="1" BorderBrush="#292929">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#191919" Offset="0"/>
                        <GradientStop Color="#121212" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <DataGrid ItemsSource="{Binding History}"
              AutoGenerateColumns="False"
              HeadersVisibility="Column"
              Background="Transparent"
              BorderThickness="0"
              Foreground="#e0e0e0"
              FontSize="16"
              RowHeight="36"
              ColumnHeaderHeight="42"
              GridLinesVisibility="None"
              CanUserAddRows="False"
              SelectionMode="Single"
              SelectionUnit="FullRow"
              IsReadOnly="true"
                >


                    <!-- === CELL STYLE (3-space indent) === -->
                    <DataGrid.Resources>
                        <Style x:Key="CellPaddingStyle" TargetType="TextBlock">
                            <Setter Property="Padding" Value="12,0,0,0"/>
                            <!-- 3-space indent -->
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.Resources>

                    <!-- === HEADER STYLE === -->
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Foreground" Value="#bdbdbd"/>
                            <Setter Property="Background" Value="#1c1c1c"/>
                            <Setter Property="FontSize" Value="15"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#292929"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="Padding" Value="12,0,0,0"/>
                            <!-- Match cell indent -->
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <!-- === ROW STYLE === -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="#181818"/>
                            <!-- normal -->
                            <Setter Property="BorderBrush" Value="#232323"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="Padding" Value="4"/>
                            <Setter Property="Foreground" Value="#e0e0e0"/>
                        </Style>
                    </DataGrid.RowStyle>

                    <!-- === COLUMNS (Correct Order + Padding) === -->
                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Action" Binding="{Binding Action}"
                                Width="*" ElementStyle="{StaticResource CellPaddingStyle}" />

                        <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}"
                                Width="*" ElementStyle="{StaticResource CellPaddingStyle}" />

                        <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}"
                                Width="*" ElementStyle="{StaticResource CellPaddingStyle}" />

                        <DataGridTextColumn Header="Price" Binding="{Binding Price}"
                                Width="*" ElementStyle="{StaticResource CellPaddingStyle}" />

                        <DataGridTextColumn Header="Total" Binding="{Binding Total}"
                                Width="*" ElementStyle="{StaticResource CellPaddingStyle}" />

                        <DataGridTextColumn Header="Time" Binding="{Binding Time}"
                                Width="2*" ElementStyle="{StaticResource CellPaddingStyle}" />

                    </DataGrid.Columns>
                </DataGrid>
            </Border>


        </Grid>
    </Border>

</UserControl>
