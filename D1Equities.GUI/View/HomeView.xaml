<UserControl x:Class="D1Equities.GUI.View.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModel="clr-namespace:D1Equities.GUI.ViewModel"
             xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
             xmlns:local="clr-namespace:D1Equities.GUI.View"
             Background="Transparent"
             MinHeight="500"
             MinWidth="900">

    <UserControl.DataContext>
        <viewModel:HomeViewModel/>
    </UserControl.DataContext>

    <!-- OUTER BORDER: Gradient border with shadow -->
    <Border CornerRadius="15" Padding="10">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#191919" Offset="0"/>
                <GradientStop Color="#121212" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <!-- Top row (3 boxes) -->
                <RowDefinition Height="3*"/>
                <!-- Bottom rectangle -->
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- TOP: 3 boxes -->
            <Border Grid.Row="0" Grid.Column="0" Margin="12" CornerRadius="8" BorderThickness="1" BorderBrush="#292929">
                
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#081e19" Offset="0"/>
                        <GradientStop Color="#0d251f" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel Orientation="Vertical" Margin="15,50,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Total Portfolio Value" Foreground="#a1a1a1" FontSize="20"
                       FontWeight="Light" VerticalAlignment="Center"/>

                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                        <TextBlock Text="$" Foreground="White" FontSize="25"
                       FontWeight="Light" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalEquity}" Foreground="White" FontSize="30"
                       FontWeight="Light" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Margin="12" CornerRadius="8" BorderThickness="1" BorderBrush="#292929">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#081e19" Offset="0"/>
                        <GradientStop Color="#0d251f" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel Orientation="Vertical" Margin="15,50,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Total Gain/Loss" Foreground="#a1a1a1" FontSize="20"
                       FontWeight="Light" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                        <TextBlock Text="+" Foreground="White" FontSize="25"
                       FontWeight="Light" VerticalAlignment="Center"/>
                        <TextBlock Text="$" Foreground="White" FontSize="25"
                       FontWeight="Light" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalValueChange}" Foreground="White" FontSize="30"
                       FontWeight="Light" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                        <TextBlock Text="+" Foreground="#a1a1a1" FontSize="20"
                       FontWeight="Light" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalPercentageChange}" Foreground="#a1a1a1" FontSize="20"
                       FontWeight="Light" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>                
            </Border>

            <Border Grid.Row="0" Grid.Column="2" Margin="12" CornerRadius="8" BorderThickness="1" BorderBrush="#292929">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#191919" Offset="0"/>
                        <GradientStop Color="#121212" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel Orientation="Vertical" Margin="15,50,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Total Holdings" Foreground="#a1a1a1" FontSize="20"
                       FontWeight="Light" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                        <TextBlock Text="{Binding TotalStocksOwned}" Foreground="White" FontSize="25"
                       FontWeight="Light" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                        <TextBlock Text="Different Stocks" Foreground="#a1a1a1" FontSize="20"
                       FontWeight="Light" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- BOTTOM rectangle -->
            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="12" CornerRadius="8">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#191919" Offset="0"/>
                        <GradientStop Color="#121212" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>


        </Grid>
    </Border>

</UserControl>
