<Window x:Class="D1Equities.GUI.View.TradeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight">

    <!-- Outer border (gradient, rounded corners, shadow) -->
    <Border CornerRadius="15" Padding="2">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#191919" Offset="0"/>
                <GradientStop Color="#121212" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" Opacity="0.3" ShadowDepth="5"/>
        </Border.Effect>

        <!-- Actual content container -->
        <Border CornerRadius="13" Background="#181818" ClipToBounds="True">

            <Grid Margin="20">

                <!-- Title bar substitute (drag window) -->
                <Border Background="#221E1E1E"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,15"
                        MouseLeftButtonDown="WindowDrag">
                    <TextBlock Text="{Binding Title}"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Light"/>
                </Border>

                <StackPanel Margin="0,60,0,0">

                    <TextBlock Text="{Binding PriceLabel}"
                               Foreground="White"
                               FontSize="16"/>

                    <TextBox Text="{Binding ShareAmount}"
                             Margin="0,10,0,10"
                             Background="#2a2a2a"
                             Foreground="White"
                             BorderBrush="#444"
                             BorderThickness="1"
                             Padding="5"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right">

                        <Button Content="Confirm"
                                Width="80"
                                Margin="0,0,10,0"
                                Command="{Binding ConfirmCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="5"
                                            BorderBrush="#555" BorderThickness="1">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#0d251f" Offset="0"/>
                                                <GradientStop Color="#12342c" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Margin="5"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Content="Cancel"
                                Width="80"
                                Command="{Binding CancelCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="5"
                                            BorderBrush="#555" BorderThickness="1">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#191919" Offset="0"/>
                                                <GradientStop Color="#121212" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Margin="5"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>

                </StackPanel>

            </Grid>

        </Border>
    </Border>
</Window>
