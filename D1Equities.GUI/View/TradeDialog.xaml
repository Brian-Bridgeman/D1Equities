<Window x:Class="D1Equities.GUI.View.TradeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        SizeToContent="WidthAndHeight">

    <!-- Outer border (gradient + shadow) -->
    <Border CornerRadius="15" Padding="2">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#191919" Offset="0"/>
                <GradientStop Color="#121212" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" Opacity="0.3" ShadowDepth="5"/>
        </Border.Effect>

        <!-- Content container -->
        <Border CornerRadius="13" Background="#181818" ClipToBounds="True">
            <Grid Margin="20">

                <!-- Title bar (draggable) -->
                <Border Background="#221E1E1E"
                        CornerRadius="8"
                        Padding="10"
                        Margin="0,0,0,15"
                        MouseLeftButtonDown="WindowDrag">
                    <TextBlock Text="{Binding Title}"
                               HorizontalAlignment="Center"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Light"/>
                </Border>

                <StackPanel Margin="0,60,0,0">

                    <!-- Price display -->
                    <!-- Shares Owned -->
                    <TextBlock Text="Shares Owned:"
                               Foreground="White"
                               FontWeight="Medium"/>
                    <TextBlock Text="{Binding SharesOwned}"
                               Foreground="White"
                               Margin="0,0,0,10"/>

                    <!-- Share Price -->
                    <TextBlock Text="Share Price:"
                               Foreground="White"
                               FontWeight="Medium"/>

                    <TextBlock Text="{Binding CurrentPrice, StringFormat=C}"
                               Foreground="White"
                               Margin="0,0,0,10"/>

                    <!-- Total Price -->
                    <TextBlock Text="Total:"
                               Foreground="White"
                               FontWeight="Medium"/>

                    <TextBlock Text="{Binding TotalPrice, StringFormat=C}"
                               Foreground="White"
                               Margin="0,0,0,10"/>
                    <!-- Balance and Remaining Balance -->
                    <TextBlock Text="Available Balance:"
                               Foreground="White"
                               FontWeight="Medium"/>

                    <TextBlock Text="{Binding Balance, StringFormat=C}"
                               Foreground="White"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Remaining Balance:"
                               Foreground="White"
                               FontWeight="Medium"/>

                    <TextBlock Text="{Binding RemainingBalance, StringFormat=C}"
                               Foreground="White"/>

                    <!-- Share amount input -->
                    <TextBox Text="{Binding ShareAmount, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                             Margin="0,10,0,10"
                             Background="#2a2a2a"
                             Foreground="White"
                             BorderBrush="#444"
                             BorderThickness="1"
                             Padding="5"
                             PreviewTextInput="NumberOnly_PreviewTextInput"
                             DataObject.Pasting="NumberOnly_Pasting"/>


                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                        <Button Content="Confirm"
                                Width="80"
                                Margin="0,0,10,0"
                                Command="{Binding ConfirmCommand}"
                                IsEnabled="{Binding CanExecuteTrade}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="5"
                BorderBrush="#555" BorderThickness="1">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#004731" Offset="0"/>
                                                <GradientStop Color="#00895d" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>

                                        <ContentPresenter x:Name="contentPresenter"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="5"
                              TextElement.Foreground="White"/>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <!-- Hover -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                        </Trigger>

                                        <!-- Pressed -->
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                                        </Trigger>

                                        <!-- Disabled -->
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                                            <Setter TargetName="contentPresenter" Property="TextElement.Foreground" Value="#666"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>



                        <!-- Cancel -->
                        <Button Content="Cancel"
                                Width="80"
                                Command="{Binding CancelCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" CornerRadius="5"
                BorderBrush="#555" BorderThickness="1">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#0D0D0D" Offset="0"/>
                                                <GradientStop Color="#121212" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>

                                        <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="5"
                              TextElement.Foreground="White"/>
                                    </Border>

                                    <ControlTemplate.Triggers>
                                        <!-- Hover -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                        </Trigger>

                                        <!-- Pressed -->
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>

                    </StackPanel>

                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
