<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--Background Colors-->
    <Color x:Key="BackgroundPrimaryColor1">#0D0D0D</Color>
    <Color x:Key="BackgroundPrimaryColor2">#242424</Color>
    <Color x:Key="BackgroundSecondaryColor1">#191919</Color>
    <Color x:Key="BackgroundSecondaryColor2">#2C2C2C</Color>

    <!--Window Border Colors-->
    <Color x:Key="WindowBorderColor1">#242424</Color>
    <Color x:Key="WindowBorderColor2">#3B3B3B</Color>

    <!--Color Palette-->
    <SolidColorBrush x:Key="CloseColor" Color="#FF2E2E"/>
    <SolidColorBrush x:Key="MinimizeColor" Color="#FFBD2E"/>
    <SolidColorBrush x:Key="MaximizeColor" Color="#2EFF4A"/>
    <SolidColorBrush x:Key="UIButtons" Color="#656565"/>
    <SolidColorBrush x:Key="UIButtonsHover" Color="#808080"/>
    <SolidColorBrush x:Key="D1Green" Color="#0bd851"/>
    <SolidColorBrush x:Key="D1GreenHover" Color="#64F795"/>


    <!--Text Colors-->
    <SolidColorBrush x:Key="plainTextColor1" Color="White"/>
</ResourceDictionary>